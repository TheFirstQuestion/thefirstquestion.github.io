<!DOCTYPE html>
<html>

<head>
	<title>Classroom Scoreboard</title>
	<link rel="stylesheet" type="text/css" href="index-style.css">
</head>

<body>

<h1>Classroom Scoreboard</h1>

<select id="select">
    <option value="example-class.txt" selected="selected">Example Class</option>
    <option value="period-9.txt">Furiak Period 9</option>
    <option value="period-10.txt">Furiak Period 10</option>
</select>


<a id="start" href="#" onclick="changeURLSelect()">Start</a>


<script>
	function changeURLSelect() {
		var input = document.getElementById("select").value;
		var url = "scoreboard.html?class=" + input;
		var element = document.getElementById('start');
		element.setAttribute("href", url);
	}
</script>






</body>


</html>
